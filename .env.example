# ---------------------------------------------------------------------------
# WindHero 逐风人 — 环境变量
#
# 本地开发：复制为 .env.local 后填入
# 生产部署：在 Vercel → Project Settings → Environment Variables 里配置
# ---------------------------------------------------------------------------

# Supabase 的公开 URL 与 anon key —— 可以暴露给浏览器
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 仅服务端使用的 service-role key
# /api/subscribe 用它绕过 RLS 写入 subscribers 表
# 千万不要加 NEXT_PUBLIC_ 前缀，也不要把它提交到任何仓库
SUPABASE_SERVICE_ROLE_KEY=

# 站点正式域名 —— 用于 metadata.canonical / sitemap
NEXT_PUBLIC_SITE_URL=https://windhero.vercel.app
