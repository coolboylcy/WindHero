# ---------------------------------------------------------------------------
# WindHero — environment variables
# Copy to .env.local for local development, and configure the same keys in
# Vercel → Project Settings → Environment Variables for production.
# ---------------------------------------------------------------------------

# Public Supabase URL & anon key — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only service-role key — used by /api/subscribe to upsert past
# RLS without requiring an authenticated session.
# DO NOT prefix with NEXT_PUBLIC_. Never commit this value.
SUPABASE_SERVICE_ROLE_KEY=

# Optional — used in metadata.canonical / sitemap when you have a domain.
NEXT_PUBLIC_SITE_URL=https://windhero.app
